{
  "name": "ts-explicit-errors",
  "version": "4.1.2",
  "description": "A TypeScript error handling library for treating errors as values",
  "keywords": [
    "error",
    "error handling",
    "result",
    "typescript"
  ],
  "homepage": "https://github.com/adamhl8/ts-explicit-errors",
  "bugs": {
    "url": "https://github.com/adamhl8/ts-explicit-errors/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhl8/ts-explicit-errors.git"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && oxfmt && oxlint --fix --fix-suggestions --fix-dangerously && adamhl8-knip && nub run test",
    "test": "vitest run",
    "bump-deps": "nub update -L && rm -f lock.yaml && nub i && oxfmt lock.yaml",
    "bundle": "nub run lint && tsdown",
    "release": "gh workflow run release.yml",
    "release:run": "release-it --ci -i \"$(adamhl8-cliff --bumped-version)\"",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@adamhl8/configs": "^0.24.9",
    "@arethetypeswrong/core": "^0.18.4",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "knip": "^6.23.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "release-it": "^20.2.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
